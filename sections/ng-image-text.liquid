{%- style -%}
  .ng-split-{{ section.id }} { padding-block: {{ section.settings.padding_top_mobile }}px {{ section.settings.padding_bottom_mobile }}px; }
  @media(min-width:990px){
    .ng-split-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; }
  }
{%- endstyle -%}

<div class="ng-split{% if section.settings.layout == 'image_right' %} ng-split--reversed{% endif %} ng-split-{{ section.id }}" style="background:{{ section.settings.bg_color }};">
  <div class="ng-split__media">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1200
        | image_tag:
          loading: 'lazy',
          widths: '600,800,1000,1200',
          sizes: '(min-width:990px) 50vw, 100vw'
      }}
    {%- else -%}
      <div style="width:100%;height:100%;min-height:40rem;background:var(--ng-bg-2);"></div>
    {%- endif -%}
  </div>
  <div class="ng-split__content{% if section.settings.content_dark %} ng-split__content--dark{% endif %}" style="{% unless section.settings.content_dark %}background:{{ section.settings.bg_color }};{% endunless %}">
    <div style="max-width:52rem;">
      {%- if section.settings.eyebrow != blank -%}
        <div class="ng-section-header__eyebrow" style="margin-bottom:1.6rem;">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 style="margin-bottom:2rem;" data-ng-reveal>{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="ng-split__text ng-rte" data-ng-reveal data-ng-delay="1">{{ section.settings.text }}</div>
      {%- endif -%}
      {%- if section.settings.btn_label != blank -%}
        <a
          href="{{ section.settings.btn_url }}"
          class="ng-btn {% if section.settings.content_dark %}ng-btn--ghost{% else %}ng-btn--primary{% endif %}"
          data-ng-reveal data-ng-delay="2"
        >{{ section.settings.btn_label }}</a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image + Texte",
  "tag": "section",
  "settings": [
    { "type": "select", "id": "layout", "label": "Position de l'image", "options": [{"value":"image_left","label":"Image à gauche"},{"value":"image_right","label":"Image à droite"}], "default": "image_left" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "header", "content": "Contenu" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre" },
    { "type": "inline_richtext", "id": "title", "label": "Titre", "default": "Notre philosophie" },
    { "type": "richtext", "id": "text", "label": "Texte", "default": "<p>Racontez votre histoire, partagez vos valeurs et créez une connexion avec vos clients.</p>" },
    { "type": "text", "id": "btn_label", "label": "Label bouton" },
    { "type": "url", "id": "btn_url", "label": "Lien bouton" },
    { "type": "header", "content": "Apparence" },
    { "type": "color", "id": "bg_color", "label": "Couleur de fond", "default": "#FFFFFF" },
    { "type": "checkbox", "id": "content_dark", "label": "Texte sur fond sombre (primaire)", "default": false },
    { "type": "header", "content": "Espacements — Bureau" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "default": 0, "unit": "px", "label": "Padding supérieur" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "default": 0, "unit": "px", "label": "Padding inférieur" },
    { "type": "header", "content": "Espacements — Mobile" },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 100, "step": 8, "default": 0, "unit": "px", "label": "Padding supérieur" },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 100, "step": 8, "default": 0, "unit": "px", "label": "Padding inférieur" }
  ],
  "presets": [{ "name": "Image + Texte" }]
}
{% endschema %}

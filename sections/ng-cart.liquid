{%- style -%}
  .ng-cart-page-{{ section.id }} {
    padding-top:    {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background:     {{ section.settings.bg_color }};
  }
  @media (min-width: 990px) {
    .ng-cart-page-{{ section.id }} {
      padding-top:    {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
    .ng-cart-page-{{ section.id }} .ng-cart-page__grid {
      grid-template-columns: 1fr {{ section.settings.summary_width }}rem;
      gap: {{ section.settings.grid_gap }}rem;
    }
  }
{%- endstyle -%}

<div class="ng-cart-page-{{ section.id }}" style="min-height:50vh;">
  <div class="ng-container" style="max-width:{{ section.settings.max_width }}rem;">

    <h1 style="margin-bottom:3.2rem;font-size:clamp(2.8rem,4vw,4.4rem);">
      {{ section.settings.heading | default: 'Mon panier' }}
      {%- if cart.item_count > 0 -%}
        <span style="font-size:1.8rem;font-weight:500;color:var(--ng-text-muted);margin-left:.8rem;">({{ cart.item_count }})</span>
      {%- endif -%}
    </h1>

    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart, id: 'ng-cart-form' -%}
        <div class="ng-cart-page__grid" style="display:grid;gap:3.2rem;align-items:start;">

          <!-- Articles -->
          <div>
            {%- for item in cart.items -%}
              <div class="ng-cart-item" style="display:grid;grid-template-columns:9.6rem 1fr;gap:2.4rem;padding-block:2.4rem;border-bottom:1px solid var(--ng-border);">
                <a href="{{ item.url }}" style="display:block;aspect-ratio:1;border-radius:var(--ng-r-md);overflow:hidden;background:var(--ng-bg-2);">
                  {%- if item.image -%}
                    {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item.product_title | escape }}
                  {%- endif -%}
                </a>
                <div style="display:flex;flex-direction:column;gap:.8rem;">
                  <a href="{{ item.url }}" style="font-size:1.5rem;font-weight:700;color:var(--ng-primary);line-height:1.3;">
                    {{ item.product_title }}
                  </a>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <span style="font-size:1.2rem;color:var(--ng-text-muted);">{{ item.variant.title }}</span>
                  {%- endunless -%}
                  {%- if item.selling_plan_allocation != nil -%}
                    <span style="font-size:1.2rem;color:var(--ng-accent);">{{ item.selling_plan_allocation.selling_plan.name }}</span>
                  {%- endif -%}
                  <div style="display:flex;align-items:center;justify-content:space-between;margin-top:auto;flex-wrap:wrap;gap:1.2rem;">
                    <div class="ng-qty" style="transform:scale(0.88);transform-origin:left;">
                      <button type="button" class="ng-qty__btn" aria-label="Diminuer la quantité">−</button>
                      <input
                        class="ng-qty__input"
                        type="number"
                        name="updates[]"
                        value="{{ item.quantity }}"
                        min="0"
                        aria-label="Quantité de {{ item.product_title | escape }}"
                        data-item-key="{{ item.key }}"
                      >
                      <button type="button" class="ng-qty__btn" aria-label="Augmenter la quantité">+</button>
                    </div>
                    <strong style="font-size:1.6rem;color:var(--ng-primary);">{{ item.final_line_price | money }}</strong>
                  </div>
                  <a
                    href="{{ item.url_to_remove }}"
                    style="font-size:1.2rem;color:var(--ng-text-muted);text-decoration:underline;text-underline-offset:2px;width:fit-content;"
                    aria-label="Supprimer {{ item.product_title | escape }}"
                  >
                    {{ section.settings.remove_label | default: 'Supprimer' }}
                  </a>
                </div>
              </div>
            {%- endfor -%}

            <!-- Bouton continuer les achats -->
            <div style="margin-top:2.4rem;">
              <a href="{{ section.settings.continue_url | default: '/collections/all' }}" style="font-size:1.3rem;font-weight:600;color:var(--ng-text-muted);text-decoration:underline;text-underline-offset:3px;">
                ← {{ section.settings.continue_label | default: 'Continuer mes achats' }}
              </a>
            </div>
          </div>

          <!-- Récapitulatif commande -->
          <div style="background:var(--ng-bg-2);border-radius:var(--ng-r-lg);padding:3.2rem;position:sticky;top:calc(var(--ng-s16) + 1rem);">
            <h3 style="font-size:2rem;margin-bottom:2.4rem;">{{ section.settings.summary_title | default: 'Récapitulatif' }}</h3>

            {%- if cart.cart_level_discount_applications.size > 0 -%}
              {%- for discount in cart.cart_level_discount_applications -%}
                <div style="display:flex;justify-content:space-between;margin-bottom:1.2rem;font-size:1.3rem;color:var(--ng-accent);">
                  <span>{{ discount.title }}</span>
                  <span>−{{ discount.total_allocated_amount | money }}</span>
                </div>
              {%- endfor -%}
            {%- endif -%}

            <div style="display:flex;justify-content:space-between;margin-bottom:1.6rem;font-size:1.6rem;padding-top:1.6rem;border-top:1px solid var(--ng-border);">
              <span>{{ section.settings.subtotal_label | default: 'Sous-total' }}</span>
              <strong>{{ cart.total_price | money }}</strong>
            </div>

            <p style="font-size:1.2rem;color:var(--ng-text-muted);margin-bottom:2.4rem;">
              {{ section.settings.shipping_note | default: 'Taxes et livraison calculées à la commande.' }}
            </p>

            <button
              type="submit"
              name="checkout"
              class="ng-btn ng-btn--primary ng-btn--full ng-btn--lg"
            >
              {{ section.settings.checkout_label | default: 'Commander' }}
            </button>

            {%- if additional_checkout_buttons -%}
              <div style="margin-top:1.6rem;">
                {{ content_for_additional_checkout_buttons }}
              </div>
            {%- endif -%}
          </div>

        </div>
      {%- endform -%}

    {%- else -%}
      <div style="text-align:center;padding-block:8rem;display:flex;flex-direction:column;align-items:center;gap:2.4rem;">
        <svg width="72" height="72" viewBox="0 0 24 24" fill="none" stroke="var(--ng-border)" stroke-width="1.2" stroke-linecap="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <h2 style="color:var(--ng-primary);">{{ section.settings.empty_title | default: 'Votre panier est vide' }}</h2>
        <p style="color:var(--ng-text-muted);font-size:1.6rem;">{{ section.settings.empty_text | default: 'Ajoutez des articles pour commencer.' }}</p>
        <a href="{{ section.settings.empty_cta_url | default: '/collections/all' }}" class="ng-btn ng-btn--primary ng-btn--lg">
          {{ section.settings.empty_cta_label | default: 'Découvrir nos produits' }}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Page panier",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Textes"
    },
    { "type": "text", "id": "heading", "label": "Titre du panier", "default": "Mon panier" },
    { "type": "text", "id": "remove_label", "label": "Label \"Supprimer\"", "default": "Supprimer" },
    { "type": "text", "id": "continue_label", "label": "Label \"Continuer les achats\"", "default": "Continuer mes achats" },
    { "type": "url",  "id": "continue_url",   "label": "Lien \"Continuer les achats\"" },
    {
      "type": "header",
      "content": "Récapitulatif"
    },
    { "type": "text", "id": "summary_title",  "label": "Titre récapitulatif", "default": "Récapitulatif" },
    { "type": "text", "id": "subtotal_label", "label": "Label sous-total", "default": "Sous-total" },
    { "type": "text", "id": "shipping_note",  "label": "Note livraison", "default": "Taxes et livraison calculées à la commande." },
    { "type": "text", "id": "checkout_label", "label": "Label bouton commander", "default": "Commander" },
    {
      "type": "header",
      "content": "Panier vide"
    },
    { "type": "text", "id": "empty_title",     "label": "Titre panier vide", "default": "Votre panier est vide" },
    { "type": "text", "id": "empty_text",      "label": "Texte panier vide", "default": "Ajoutez des articles pour commencer." },
    { "type": "text", "id": "empty_cta_label", "label": "Label CTA panier vide", "default": "Découvrir nos produits" },
    { "type": "url",  "id": "empty_cta_url",   "label": "Lien CTA panier vide" },
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 80, "max": 160, "step": 8, "default": 120,
      "unit": "rem", "label": "Largeur max du contenu"
    },
    {
      "type": "range",
      "id": "summary_width",
      "min": 28, "max": 52, "step": 2, "default": 40,
      "unit": "rem", "label": "Largeur colonne récapitulatif (bureau)"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 2, "max": 10, "step": 1, "default": 5,
      "unit": "rem", "label": "Écart articles / récapitulatif (bureau)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Espacements — Bureau"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 32, "max": 120, "step": 8, "default": 64,
      "unit": "px", "label": "Padding supérieur (bureau)"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 32, "max": 120, "step": 8, "default": 80,
      "unit": "px", "label": "Padding inférieur (bureau)"
    },
    {
      "type": "header",
      "content": "Espacements — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 24, "max": 80, "step": 8, "default": 40,
      "unit": "px", "label": "Padding supérieur (mobile)"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 24, "max": 80, "step": 8, "default": 56,
      "unit": "px", "label": "Padding inférieur (mobile)"
    }
  ]
}
{% endschema %}

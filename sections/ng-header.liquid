{%- liquid
  assign cart_icon = settings.cart_icon | default: 'bag'
  assign logo_text = settings.logo_text | default: shop.name
-%}

{%- if settings.announce_enabled and section.settings.show_announce -%}
  {%- liquid
    case settings.announce_color
      when 'accent'
        assign announce_bg = settings.color_accent
      when 'dark'
        assign announce_bg = '#0A0A0A'
      else
        assign announce_bg = settings.color_primary
    endcase
  -%}
  <div class="ng-announce" style="background:{{ announce_bg }};">
    <div class="ng-container">{{ settings.announce_text }}</div>
  </div>
{%- endif -%}

<div class="ng-header-wrap">
  <div class="ng-container">
    <header class="ng-header" role="banner">

      {# ── Logo ── #}
      <div class="ng-header__logo">
        <a href="/" aria-label="{{ shop.name }}" style="display:flex;align-items:center;">
          {%- if settings.logo != blank -%}
            <img
              src="{{ settings.logo | image_url: width: 300 }}"
              alt="{{ shop.name }}"
              width="{{ settings.logo_width }}"
              height="auto"
              loading="eager"
              fetchpriority="high"
              style="max-width:{{ settings.logo_width }}px;"
            >
          {%- else -%}
            <span class="ng-header__logo-text">{{ logo_text }}</span>
          {%- endif -%}
        </a>
      </div>

      {# ── Desktop Nav ── #}
      <nav class="ng-header__nav" aria-label="Navigation principale">
        <ul class="ng-nav__list" role="list">
          {%- for link in linklists[settings.main_menu].links -%}
            <li class="ng-nav__item{% if link.links.size > 0 %} ng-nav__item--has-sub{% endif %}">
              <a
                href="{{ link.url }}"
                class="ng-nav__link{% if link.active %} is-active{% endif %}"
                {% if link.links.size > 0 %}aria-haspopup="true" aria-expanded="false"{% endif %}
              >
                {{ link.title }}
                {%- if link.links.size > 0 -%}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left:4px;transition:transform .2s;"><polyline points="6 9 12 15 18 9"/></svg>
                {%- endif -%}
              </a>
              {%- if link.links.size > 0 -%}
                <div class="ng-nav__dropdown" role="menu">
                  {%- for sub in link.links -%}
                    <a href="{{ sub.url }}" class="ng-nav__dropdown-link" role="menuitem">{{ sub.title }}</a>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>

      {# ── Actions ── #}
      <div class="ng-header__actions">
        {%- if settings.show_search -%}
          <button class="ng-icon-btn" data-ng-search-open aria-label="{{ 'general.search.search' | t }}" aria-expanded="false">
            {%- render 'ng-icon', icon: 'search' -%}
          </button>
        {%- endif -%}

        {%- if settings.show_account -%}
          <a href="{%- if customer -%}/account{%- else -%}/account/login{%- endif -%}" class="ng-icon-btn" aria-label="Compte client">
            {%- render 'ng-icon', icon: 'user' -%}
          </a>
        {%- endif -%}

        <button class="ng-icon-btn" data-ng-cart-open aria-label="{{ 'cart.general.title' | t }}" style="position:relative;">
          {%- render 'ng-icon', icon: cart_icon -%}
          <span class="ng-cart-badge{% if cart.item_count == 0 %} ng-hidden{% endif %}" aria-label="{{ cart.item_count }} articles">
            <span class="ng-cart-count-val">{{ cart.item_count }}</span>
          </span>
        </button>

        {# Mobile burger #}
        <button
          id="ng-burger"
          class="ng-burger"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="ng-mobile-nav"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>
  </div>
</div>

{# ── Mobile Nav ── #}
<div id="ng-mobile-nav" class="ng-mobile-nav" role="dialog" aria-label="Menu mobile" aria-hidden="true">
  <div class="ng-mobile-nav__overlay" aria-hidden="true"></div>
  <div class="ng-mobile-nav__panel">
    <div class="ng-mobile-nav__header">
      <span class="ng-header__logo-text" style="color:var(--ng-primary)">{{ logo_text }}</span>
      <button id="ng-mobile-nav-close" class="ng-icon-btn" aria-label="Fermer">
        {%- render 'ng-icon', icon: 'close' -%}
      </button>
    </div>
    <nav class="ng-mobile-nav__body" aria-label="Menu mobile">
      {%- for link in linklists[settings.main_menu].links -%}
        {%- if link.links.size > 0 -%}
          <div class="ng-mobile-nav__has-sub">
            <a href="{{ link.url }}" class="ng-mobile-nav__link">
              {{ link.title }}
              <button class="ng-mobile-nav__toggle ng-icon-btn" aria-label="Ouvrir le sous-menu">
                {%- render 'ng-icon', icon: 'chevron-down', size: 18 -%}
              </button>
            </a>
            <div class="ng-mobile-nav__sub">
              {%- for sub in link.links -%}
                <a href="{{ sub.url }}" class="ng-mobile-nav__sub-link">{{ sub.title }}</a>
              {%- endfor -%}
            </div>
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="ng-mobile-nav__link">{{ link.title }}</a>
        {%- endif -%}
      {%- endfor -%}
    </nav>
    <div class="ng-mobile-nav__footer">
      {%- if settings.show_search -%}
        <form action="/search" method="get" style="margin-bottom:1.6rem;">
          <input type="hidden" name="type" value="product">
          <div style="display:flex;border:1.5px solid var(--ng-border);border-radius:4px;overflow:hidden;">
            <input type="search" name="q" placeholder="Rechercher…" style="flex:1;padding:1.2rem;border:none;font-size:1.4rem;color:var(--ng-primary);">
            <button type="submit" style="padding:0 1.6rem;background:var(--ng-primary);color:#fff;border:none;cursor:pointer;">
              {%- render 'ng-icon', icon: 'search', size: 18 -%}
            </button>
          </div>
        </form>
      {%- endif -%}
      <div style="display:flex;gap:.8rem;flex-wrap:wrap;">
        {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" class="ng-icon-btn" aria-label="Instagram" style="border:1.5px solid var(--ng-border);border-radius:4px;">{%- render 'ng-icon', icon: 'instagram', size: 18 -%}</a>
        {%- endif -%}
        {%- if settings.social_tiktok != blank -%}
          <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" class="ng-icon-btn" aria-label="TikTok" style="border:1.5px solid var(--ng-border);border-radius:4px;">{%- render 'ng-icon', icon: 'tiktok', size: 18 -%}</a>
        {%- endif -%}
        {%- if settings.social_facebook != blank -%}
          <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" class="ng-icon-btn" aria-label="Facebook" style="border:1.5px solid var(--ng-border);border-radius:4px;">{%- render 'ng-icon', icon: 'facebook', size: 18 -%}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "class": "ng-header-section",
  "limit": 1,
  "settings": [
    { "type": "checkbox", "id": "show_announce", "label": "Afficher la barre d'annonce", "default": true },
    { "type": "header", "content": "Espacements" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 40, "step": 4, "default": 20, "unit": "px", "label": "Padding supérieur" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 40, "step": 4, "default": 20, "unit": "px", "label": "Padding inférieur" }
  ]
}
{% endschema %}
